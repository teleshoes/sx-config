#!/usr/bin/perl
use strict;
use warnings;
use lib `dirname $0 | tr -d '\n'`;
use PhoneBackupUtils;

sub createCameraDirs();
sub patchAdvancedCamera();
sub getDCIMUri();
sub editOpenCameraPrefs();
sub copyGCamXml();

my $IPMAGIC_NAME = "sx";
my $USER = "nemo";

my $BASE_DIR = `dirname $0 | tr -d '\n'`;
my $GCAM_XML = "$BASE_DIR/backup/gcam-xml/gcam.xml";

my $OPENCAMERA_DATA_DIR = "/home/.appsupport/instance/$USER/data/data/net.sourceforge.opencamera";
my $PREFS_XML_FILE = "$OPENCAMERA_DATA_DIR/shared_prefs/net.sourceforge.opencamera_preferences.xml";

my $SDCARD_BLOCK_DEV = "/dev/mmcblk0p2";
my $DCIM_PATH = "DCIM/OpenCamera",

my $PREFS_TEMPLATE = [
  ["preference_camera_api"              => "string"   => "preference_camera_api_camera2"],

  ["preference_using_saf"               => "boolean"  => "true"],
  ["preference_save_location_saf"       => "string"   => "%DCIM_URI%"],

  ["focus_value_0_false"                => "string"   => "focus_mode_manual2"],
  ["preference_focus_distance"          => "float"    => "3.3533278"],
  ["preference_focus_assist"            => "string"   => "2"],  #0=none, 2=2x, 4=4x
  ["preference_startup_focus"           => "boolean"  => "false"],

  ["preference_show_whats_new"          => "boolean"  => "false"],

  ["preference_show_white_balance_lock" => "boolean"  => "true"],
];

my @CAM_DIRS = (
  "/home/$USER/Pictures/Camera",
  "/home/$USER/Videos/Camera",
  "/home/$USER/Videos/Camera/.recording",
  "/home/$USER/Pictures/AdvancedCam",
  "/home/$USER/Videos/AdvancedCam",
  "/home/$USER/Pictures/Screenshots",

  "/media/sdcard/phone/Pictures/Camera",
  "/media/sdcard/phone/Videos/Camera",
  "/media/sdcard/phone/Pictures/AdvancedCam",
  "/media/sdcard/phone/Videos/AdvancedCam",
);

my $ADV_CAM_QML_FILE = "/usr/share/harbour-advanced-camera/qml/pages/CameraUI.qml";
my $ADV_CAM_PATCH = ""
  . "--- CameraUI.qml\n"
  . "+++ /usr/share/harbour-advanced-camera/qml/pages/CameraUI.qml\n"
  . "@@ -583,7 +583,7 @@\n"
  . "         id: mouseFocusArea\n"
  . "         anchors.fill: parent\n"
  . "         z: -1 //Send to back\n"
  . "-        onClicked: {\n"
  . "+        onPressAndHold: {\n"
  . " \n"
  . "             if (settingsOverlay.panelOpen) {\n"
  . "                 settingsOverlay.hideAllPanels()\n"
;

sub main(@){
  createCameraDirs();

  patchAdvancedCamera();

  editOpenCameraPrefs();

  copyGCamXml();
}

sub createCameraDirs(){
  print "\n\ncreating camera dirs\n";
  my $cmd = "set -x\n";
  $cmd .= "mkdir -p $_\n" foreach @CAM_DIRS;
  system "ipmagic", $IPMAGIC_NAME, "-s", $cmd;
}

sub patchAdvancedCamera(){
  my $tmpPatch = "/tmp/adv-cam-patch";
  print "\n\npatchin adv-cam to use long-press instead of tap to focus\n";
  open FH, "> $tmpPatch" or die "$!\n";
  print FH $ADV_CAM_PATCH;
  close FH;

  system "ipmagic", $IPMAGIC_NAME, "--rsync", "-avP",
    "$tmpPatch",
    ":$tmpPatch";

  system "rm", $tmpPatch;

  system "ipmagic", $IPMAGIC_NAME, "-u", "root", "-s", ""
    . "echo"
    . "  && echo -ne reversing patch: "
    . "  && ( patch --silent -R -f $ADV_CAM_QML_FILE $tmpPatch >/dev/null"
    . "       && echo reversed || echo skipped )"
    . "  && patch -N -f $ADV_CAM_QML_FILE $tmpPatch"
    . "  && rm $tmpPatch"
  ;
}

sub getDCIMUri(){
  my $sdcardUUID = getIpmagicBlockDevUUID($IPMAGIC_NAME, $SDCARD_BLOCK_DEV);
  my $path = $DCIM_PATH;
  $path =~ s/\//%2F/g;
  return "content://com.android.externalstorage.documents/tree/$sdcardUUID%3A$path";
}

sub editOpenCameraPrefs(){
  my $dcimUri = getDCIMUri();

  my $contents = "";
  if(ipmagicTest $IPMAGIC_NAME, "root", "-f", $PREFS_XML_FILE){
    $contents = readProc "ipmagic", $IPMAGIC_NAME, "-u", "root", "cat", $PREFS_XML_FILE;
  }

  my $prefs = {};
  for my $prefArr(@$PREFS_TEMPLATE){
    my ($key, $type, $val) = @$prefArr;
    $val =~ s/%DCIM_URI%/$dcimUri/g;
    $$prefs{$key} = {type => $type, value => $val};
  }

  my @prefLines;

  print "\n\n";
  my $oldPrefs = {};
  for my $line(split /\n/, $contents){
    next if $line =~ /^(<\?xml|<map>|<\/map>)/;
    next if $line =~ /^\s+$/;

    my ($type, $key, $val);
    if($line =~ /^\s*<(boolean|float|int)\s+name="([^"]+)"\s+value="([^"]*)"\s*\/\s*>\s*$/){
      ($type, $key, $val) = ($1, $2, $3);
    }elsif($line =~ /^\s*<(string)\s+name="([^"]+)">(.*)<\s*\/\s*string>\s*$/){
      ($type, $key, $val) = ($1, $2, $3);
    }else{
      die "ERROR: malformed opencamera prefs line $line\n";
    }

    if(defined $$prefs{$key}){
      my $newType = $$prefs{$key}{type};
      my $newVal = $$prefs{$key}{value};
      if($type eq $newType and $val eq $newVal){
        #pref is already set
        delete $$prefs{$key};
        push @prefLines, $line;
      }else{
        print "removing old $key=$val\n";
      }
    }else{
      push @prefLines, $line;
    }
  }

  my $isChanged = 0;
  for my $key(sort keys %$prefs){
    my $type = $$prefs{$key}{type};
    my $val = $$prefs{$key}{value};
    my $line;
    if($type eq "string"){
      $line = "    <$type name=\"$key\">$val</$type>";
    }else{
      $line = "    <$type name=\"$key\" value=\"$val\" />";
    }
    print "adding $key=$val\n";
    $isChanged = 1;
    push @prefLines, $line;
  }

  print "\n\n";

  my @lines = (
    "<?xml version='1.0' encoding='utf-8' standalone='yes' ?>",
    "<map>",
    @prefLines,
    "</map>",
  );
  my $newContents = join("", map {"$_\n"} @lines);

  if($isChanged){
    my $tmpFile = "/tmp/setup-opencamera-" . nowMillis();
    writeFile $tmpFile, $newContents;
    run "ipmagic", $IPMAGIC_NAME, "-u", "root",
      "mkdir", "-p", "$OPENCAMERA_DATA_DIR/shared_prefs";
    run "ipmagic", $IPMAGIC_NAME, "-u", "root",
      "--rsync", "-avP", $tmpFile, ":$PREFS_XML_FILE";
    run "ipmagic", $IPMAGIC_NAME, "-u", "root",
      "chown", "-R", "$OPENCAMERA_DATA_DIR/shared_prefs",
      "--reference=$OPENCAMERA_DATA_DIR/cache";

    if(defined $$prefs{preference_save_location_saf}){
      print "\n\n\n#####\nNOTE: URI GRANT NEEDED FOR SAF LOCATION UPDATE\n";
    }
  }else{
    print "NO CHANGE IN PREFS\n";
  }
}

sub copyGCamXml(){
  my $pkg = "com.shamim.cam";
  my $app = "SGCAM";

  my @apks = grep {-f $_} glob "$BASE_DIR/apks/*_${pkg}_*";
  my $apk;
  if(@apks == 1){
    $apk = $apks[0];
  }else{
    die "ERROR: could not find apk for gcam app $pkg\n";
  }

  my $version;
  if($apk =~ /_${pkg}_(\d+\.\d+\.\d+)/){
    $version = $1;
  }else{
    die "ERROR: could not read MAJ.MIN.PT version from $apk file name\n";
  }

  my $remoteXmlDir = "/home/$USER/android_storage/$app/$version/XML";
  system "ipmagic", $IPMAGIC_NAME, "mkdir", "-p", $remoteXmlDir;

  system "ipmagic", $IPMAGIC_NAME, "--rsync", "-avP", "-L", $GCAM_XML, ":$remoteXmlDir/";

  print "\n\n\n\n#############################\n";
  print "OPEN $app AND DOUBLE-TAP NEAR SHUTTER BUTTON\n\n";
  print "   MAYBE TWICE, CHECK THAT LENS OPTION LABELS CHANGE\n";
}

&main(@ARGV);
