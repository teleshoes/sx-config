#!/usr/bin/perl
use strict;
use warnings;
use lib `dirname $0 | tr -d '\n'`;
use PhoneBackupUtils;

my $IPMAGIC_NAME = "sx";
my $USER = "root";

sub setupCpanConfig();

my @MODULES_ARR = (
  qtemail => [qw(
    Net::SSLeay
    Mail::IMAPClient
    IO::Socket::SSL
    Date::Parse
    MIME::Lite
    MIME::Parser
    Encode::HanExtra
  )],
  klompbigtext => [qw(
    Text::CSV
  )],
  robinhood => [qw(
    JSON
  )],
  tasmota => [qw(
    Parallel::ForkManager
  )],
  utils => [qw(
    DateTime
    XML::LibXML
    Cpanel::JSON::XS
  )],
);
my %MODULES = @MODULES_ARR;
my @GROUP_NAMES = map {$MODULES_ARR[$_]} grep {$_ % 2 == 0} (0..$#MODULES_ARR);

my $MODULES_FORMAT = join('', map {"    $_ => @{$MODULES{$_}}\n"} @GROUP_NAMES);

my $USAGE = "Usage:
  $0 [MODULE_GROUP MODULE_GROUP ..]
    install cpan module groups indicated
      (default is to install all if none are given)

    \n$MODULES_FORMAT
";

sub main(@){
  die $USAGE if @_ == 1 and $_[0] =~ /^(-h|--help)$/;

  setupCpanConfig();

  run "ipmagic", $IPMAGIC_NAME, "-u", $USER,
    "yes \"\" | perl -MCPAN -e \"CPAN::Shell->notest('install', 'CPAN')\"";

  setupCpanConfig();

  my @groups = @_;
  @groups = @GROUP_NAMES if @_ == 0;
  for my $group(@groups){
    die "$USAGE\n\nunknown module group: $group\n" if not defined $MODULES{$group};
    my @modules = @{$MODULES{$group}};

    my @cpanInstallArgs = ("install", @modules);
    my $cpanInstallArgStr = join ", ", map {"'$_'"} @cpanInstallArgs;

    run "ipmagic", $IPMAGIC_NAME, "-u", $USER,
      "yes \"\" | perl -MCPAN -e \"CPAN::Shell->notest($cpanInstallArgStr)\"";
  }

  #build encodings after install
  run "ipmagic", $IPMAGIC_NAME, "-u", $USER, "enc2xs", "-C";
}

sub setupCpanConfig(){
  run "ipmagic", $IPMAGIC_NAME, "-u", $USER, "cpanp 's conf pushy_https 0; s save'";
  run "ipmagic", $IPMAGIC_NAME, "-u", $USER, "cpanp 's conf prereqs 1; s save'";

  run "ipmagic", $IPMAGIC_NAME, "-u", $USER, ''
    . '( echo;'
    . '  echo o conf pushy_https 0;'
    . '  echo o conf prerequisites_policy follow;'
    . '  echo o conf commit;'
    . ') | cpan';
}

&main(@ARGV);
