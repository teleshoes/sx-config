#!/usr/bin/perl
use strict;
use warnings;

sub run(@);

my $USAGE = "Usage:
  $0 OPTS
    run nfcd and extract the first URL from the log that looks like a yubikey

  OPTS
    -g | --get | copy | --copy | cb | --cb | clipboard | --clipboard
      copy to clipboard after extracting
";

sub main(@){
  my $opts = {
    clipboard => 0,
  };
  while(@_ > 0){
    my $arg = shift @_;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(-g|--get|copy|--copy|cb|--cb|clipboard|--clipboard)$/){
      $$opts{clipboard} = 1;
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }

  my $killNfcdCmd = "sudo pkill nfcd";
  print STDERR "$killNfcdCmd\n";
  system $killNfcdCmd;

  my $nfcdCmd = "sudo nfcd -v";
  print STDERR "$nfcdCmd\n";

  print STDERR "waiting for nfc\n";
  my $pid = open CMD, "-|", $nfcdCmd or die "ERROR: could not run nfcd\n$!\n";

  my $key = "";
  while(my $line = <CMD>){
    if($line =~ /URI Record: https:\/\/my\.yubico\.com\/\w+\/#?([a-z]+)/){
      $key = $1;
      kill "TERM", $pid;
      last;
    }
  }
  close CMD;

  system $killNfcdCmd;

  print STDERR "key: $key\n";

  print "$key\n";

  if($$opts{clipboard}){
    print STDERR "copy to clipboard (dismiss dialog first) [Y/n] ";
    my $response = <STDIN>;
    print STDERR "\n";

    if($response !~ /n/i){
      system "qclipboard-set", $key;
    }
  }
}

#2021-01-18 21:08:57 [nfc-core] URI Record: https://my.yubico.com/neo/vvfrdlirctnrditnblkncnbjbilukhijdflnrnvefbgt

&main(@ARGV);
