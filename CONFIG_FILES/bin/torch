#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);

sub killFlashlight();
sub forceFlashlightOn();
sub closeOpenCamera();
sub restartCameraWithCamera1Api();
sub toggleFlashlight();
sub isFlashlightOn();

my $EXEC = basename $0;

my $DBUS_SERVICE = "com.jolla.settings.system.flashlight";
my $DBUS_PATH = "/com/jolla/settings/system/flashlight";
my $DBUS_METHOD_TOGGLE = "com.jolla.settings.system.flashlight.toggleFlashlight";
my $DBUS_METHOD_GET = "org.freedesktop.DBus.Properties.Get";
my $DBUS_PROPERTY_FLASHLIGHT_ON = "flashlightOn";

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC
    same as: $EXEC --toggle

  $EXEC g | -g | get | --get
    -read dbus property $DBUS_PROPERTY_FLASHLIGHT_ON from $DBUS_SERVICE
    -print 'on' or 'off'

  $EXEC --dbus-toggle
    -call method $DBUS_METHOD_TOGGLE in $DBUS_SERVICE

  $EXEC t | -t | toggle | --toggle
    -read STATUS as in '$EXEC --get'
    -if <STATUS> is 'on':  same as '$EXEC --off'
    -if <STATUS> is 'off': same as '$EXEC --on'

  $EXEC on | --on
    -run: '$EXEC --off'
    -kill jolla-settings-system-flashlight
    -ensure camera1 api in droidmedia
      -run: `cam --camera1`
      -if camera2 was in place, run: `cam --kill && sleep 2`
    -close opencamera app if it is on top or screen is locked
      -run: `cam --kill-cmd opencamera`
    -run `$EXEC --dbus-toggle`

  $EXEC off | --off
    -read STATUS with: `$EXEC --get`
    -if <STATUS> is 'on', run: `$EXEC --dbus-toggle`
    -kill jolla-settings-system-flashlight
";

my $MODE_GET = "get";
my $MODE_DBUS_TOGGLE = "dbus-toggle";
my $MODE_TOGGLE = "toggle";
my $MODE_ON = "on";
my $MODE_OFF = "off";

sub main(@){
  my $mode = $MODE_TOGGLE;
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(g|-g|get|--get)$/){
      $mode = $MODE_GET;
    }elsif($arg =~ /^(t|-t|toggle|--toggle)$/){
      $mode = $MODE_TOGGLE;
    }elsif($arg =~ /^(--dbus-toggle)$/){
      $mode = $MODE_DBUS_TOGGLE;
    }elsif($arg =~ /^(on|--on)$/){
      $mode = $MODE_ON;
    }elsif($arg =~ /^(off|--off)$/){
      $mode = $MODE_OFF;
    }else{
      die "ERROR: unknown arg $arg\n";
    }
  }

  my $wasOn = isFlashlightOn();

  if($mode eq $MODE_GET){
    print $wasOn ? "on\n" : "off\n";
  }elsif($mode eq $MODE_DBUS_TOGGLE){
    toggleFlashlight();
  }elsif($mode eq $MODE_TOGGLE){
    if($wasOn){
      toggleFlashlight();
    }
    killFlashlight();

    if(not $wasOn){
      forceFlashlightOn();
    }
  }elsif($mode eq $MODE_ON){
    if($wasOn){
      toggleFlashlight();
    }
    killFlashlight();

    forceFlashlightOn();
  }elsif($mode eq $MODE_OFF){
    if($wasOn){
      toggleFlashlight();
    }
    killFlashlight();
  }else{
    die "ERROR: unknown mode $mode\n";
  }
}

sub killFlashlight(){
  system "pkill", "-f", "-9", "jolla-settings-system-flashlight";
}
sub forceFlashlightOn(){
  closeOpenCamera();
  restartCameraWithCamera1Api();
  killFlashlight();
  toggleFlashlight();
}

sub closeOpenCamera(){
  #open camera blocks flash if its the top-level app even if locked
  my $winTitle = `cat /tmp/lipstick-window-title 2>/dev/null`;
  if($winTitle =~ /^(Lock Screen|net.sourceforge.opencamera)$/){
    system "cam", "--kill-cmd", "opencamera";
  }
}

sub restartCameraWithCamera1Api(){
  my $prevLink = readlink "/usr/libexec/droid-hybris/system/lib64/libdroidmedia.so";
  #ensure camera1 unless link was already in place
  if($prevLink !~ /libdroidmedia\.so\.orig/){
    system "cam", "--camera1";
  }

  #additionally restart cameras if camera2 api droidmedia was in place
  if($prevLink =~ /camera2/){
    system "cam", "--kill";
    system "sleep", 2;
  }
}

sub toggleFlashlight(){
  my @cmd = ("dbus-send",
    "--print-reply",
    "--dest=$DBUS_SERVICE",
    "$DBUS_PATH",
    "$DBUS_METHOD_TOGGLE",
  );

  system "@cmd >/dev/null";
}

sub isFlashlightOn(){
  my @cmd = ("dbus-send",
    "--print-reply",
    "--dest=$DBUS_SERVICE",
    "$DBUS_PATH",
    "$DBUS_METHOD_GET",
    "string:$DBUS_SERVICE",
    "string:$DBUS_PROPERTY_FLASHLIGHT_ON",
  );

  my $out = `@cmd`;
  if($out =~ /^\s*variant\s+boolean\s+(true|false)$/m){
    my $val = $1;
    return $val eq "true" ? 1 : 0;
  }else{
    die "ERROR: could not parse property $DBUS_PROPERTY_FLASHLIGHT_ON in $DBUS_SERVICE\n$out";
  }
}

&main(@ARGV);
