from PyQt5.QtCore import *
from PyQt5.QtQuick import *
from PyQt5.QtWidgets import *

import argparse
import os
import re
import sys
import signal
import tempfile

signal.signal(signal.SIGINT, signal.SIG_DFL)

def main():
  parser = argparse.ArgumentParser(description="open a QT window with the image displayed")
  parser.add_argument("-p", "--portrait",
                      dest="ORIENTATION", action="store_const", const="Portrait",
                      help=("disable auto-rotate, force portrait orientation"))
  parser.add_argument("-l", "--landscape",
                      dest="ORIENTATION", action="store_const", const="Landscape",
                      help=("disable auto-rotate, force landscape orientation"))
  parser.add_argument("-a", "--auto-rotate",
                      dest="ORIENTATION", action="store_const", const="All",
                      help=("enable auto-rotate (this is the default)"))
  parser.add_argument('imgFile',
                      help="image file, absolute or relative path")

  args = parser.parse_args()

  imgFile = os.path.abspath(args.imgFile)
  if not os.path.exists(imgFile):
    print("ERROR: " + imgFile + " does not exist")
    sys.exit(1)

  allowedOrientations = "All"
  if args.ORIENTATION:
    allowedOrientations = args.ORIENTATION

  os.environ['QT_QPA_PLATFORM']='wayland'
  os.environ['XDG_RUNTIME_DIR']='/run/user/100000'
  os.environ['WAYLAND_DISPLAY']='../../display/wayland-0'

  app = QApplication([])

  qml = getQML({"imgFile":imgFile, "allowedOrientations":allowedOrientations})

  fd, qmlFile = tempfile.mkstemp(prefix="imgview_", suffix=".qml")
  fh = open(qmlFile, 'w')
  fh.write(qml)
  fh.close()

  mainWindow = QQuickView()
  mainWindow.setSource(QUrl(qmlFile))

  mainWindow.show()

  app.exec_()

def getQML(props):
  return """
import QtQuick 2.0
import QtQuick.Window 2.2
import Sailfish.Silica 1.0

ApplicationWindow {
  initialPage: Component {
    Page {
      id: page
      allowedOrientations: Orientation.%(allowedOrientations)s

      // handle orientation changes after page is active
      onWidthChanged: img.resetZoom()

      Timer {
        id: resetZoomTimer
        repeat: false
        interval: 50
        onTriggered: img.resetZoom()
      }

      Item{
        id: imgContainer
        anchors.fill: parent

        PinchArea {
          anchors.fill: parent
          pinch.target: img
          pinch.minimumScale: 0.1
          pinch.maximumScale: 10

          MouseArea {
            id: mouseArea
            anchors.fill: parent
            drag.target: img
            property int clickCount: 0

            Timer {
              id: resetClickCountTimer
              interval: 500
              repeat: false
              onTriggered: mouseArea.clickCount = 0
            }
            onClicked: {
              if(++clickCount == 2){
                //double-click
                img.resetZoom()
                clickCount = 0
                resetClickCountTimer.stop()
              }else{
                resetClickCountTimer.restart()
              }
            }
          }
        }

        Image{
          id: img
          source: 'file://%(imgFile)s'
          Component.onCompleted: resetZoomTimer.start()

          function resetZoom(){
            var scaleW = page.width / img.paintedWidth
            var scaleH = page.height / img.paintedHeight
            var scale = (scaleW < scaleH) ? scaleW : scaleH

            img.scale = scale
            img.x = (page.width - img.width) / 2
            img.y = (page.height - img.height) / 2
          }
        }
      }
    }
  }

  cover: Component {
    Cover {
      transparent: true

      Image {
        id: imgCover
        source: 'file://%(imgFile)s'
        anchors.fill: parent
        fillMode: Image.PreserveAspectFit
      }
      Label {
        anchors.centerIn: parent
        text: "%(imgFile)s"
        wrapMode: Text.WrapAnywhere
        width: parent.width
      }
    }
  }
}
""" % props

if __name__ == "__main__":
  sys.exit(main())
