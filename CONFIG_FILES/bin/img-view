from PyQt5.QtCore import *
from PyQt5.QtQuick import *
from PyQt5.QtWidgets import *

import os
import re
import sys
import signal
import tempfile

signal.signal(signal.SIGINT, signal.SIG_DFL)

usage = """Usage:
  %(exec)s IMG_FILE
    open a QT window with the image displayed

""" % {"exec": sys.argv[0]}

def main():
  imgFile = None
  if len(sys.argv) == 2:
    imgFile = sys.argv[1]
  else:
    sys.stderr.write(usage)
    sys.exit(2)

  imgFile = os.path.abspath(imgFile)

  os.environ['QT_QPA_PLATFORM']='wayland'
  os.environ['XDG_RUNTIME_DIR']='/run/user/100000'
  os.environ['WAYLAND_DISPLAY']='../../display/wayland-0'

  app = QApplication([])

  qml = getQML(imgFile)

  fd, qmlFile = tempfile.mkstemp(prefix="imgview_", suffix=".qml")
  fh = open(qmlFile, 'w')
  fh.write(qml)
  fh.close()

  mainWindow = QQuickView()
  mainWindow.setSource(QUrl(qmlFile))

  mainWindow.show()

  app.exec_()

def getQML(imgFile):
  return """
import QtQuick 2.0
import QtQuick.Window 2.2
import Sailfish.Silica 1.0

ApplicationWindow {
  initialPage: Component {
    Page {
      id: page
      allowedOrientations: Orientation.All

      // handle orientation changes after page is active
      onWidthChanged: img.resetZoom()

      Timer {
        id: resetZoomTimer
        repeat: false
        interval: 50
        onTriggered: img.resetZoom()
      }

      Item{
        id: imgContainer
        anchors.fill: parent

        PinchArea {
          anchors.fill: parent
          pinch.target: img
          pinch.minimumScale: 0.1
          pinch.maximumScale: 10

          MouseArea {
            anchors.fill: parent
            drag.target: img
            onDoubleClicked: img.resetZoom()
          }
        }

        Image{
          id: img
          source: 'file://%(imgFile)s'
          Component.onCompleted: resetZoomTimer.start()

          function resetZoom(){
            var scaleW = page.width / img.paintedWidth
            var scaleH = page.height / img.paintedHeight
            var scale = (scaleW < scaleH) ? scaleW : scaleH

            img.scale = scale
            img.x = (page.width - img.width) / 2
            img.y = (page.height - img.height) / 2
          }
        }
      }
    }
  }
}
""" % {"imgFile": imgFile}


if __name__ == "__main__":
  sys.exit(main())
