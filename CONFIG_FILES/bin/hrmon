#!/usr/bin/perl
use strict;
use warnings;
use Date::Parse qw(str2time);
use File::Basename qw(basename);

sub detectMAC();
sub getLogFiles();
sub getLastHeartrateLogEntry();
sub formatRelativeTime($);
sub readProc(@);
sub stopHrmon();
sub run(@);

my $DEVICES = [
  {devType => "H10", mac => "A0:9E:1A:D0:56:2E", readHandle=>"0x0010", ctlHandle=>"0x0011"},
  {devType => "H7",  mac => "00:22:D0:44:94:5A", readHandle=>undef,    ctlHandle=>undef},
];
my @ALL_MACS = map {$$_{mac}} @$DEVICES;

my $ELAPSED_TIME_THRESHOLD_SECONDS = 60;
my $BT_DETECT_TIMEOUT = 5;
my $MAX_ELAPSED_BT_DETECT = 30;

my $BT_DETECT_EXEC = "bt-detect";
my $BLE_HRL_EXEC = "BLEHeartRateLogger.py";

my $LOG_DIR = "$ENV{HOME}/.cache/logs/hrmon";

my $EXEC = basename $0;

my $USAGE = "Usage:
  $EXEC -h | --help
    show this message

  $EXEC
  $EXEC --screen-daemon | --ensure-attach | ensure-attach
    ensure screen-daemon is running and attach to it
      -run: 'screen-daemon hrmon --ensure-attach'

  $EXEC -g | g
  $EXEC --get | get
    print either the heartrate if its very recent, or 'waiting', or 'off'
      -get the <STATUS> as in: `$EXEC --status`
      -get the <ELAPSED_TIME_S> and HEARTRATE as in: `$EXEC --last`
      -if STATUS is 'off':
        -print 'off'
      -if STATUS is 'on' and ELAPSED_TIME_S >= ${ELAPSED_TIME_THRESHOLD_SECONDS}s:
        -print 'waiting'
      -if STATUS is 'on' and ELAPSED_TIME_S < ${ELAPSED_TIME_THRESHOLD_SECONDS}s:
        -print '<HEARTRATE>' (e.g.: '120')

  $EXEC --mac | --dev | --detect-mac | --detect-dev
    scan for BLE devices among known MACS with bluetoothctl + expect
      -repeatedly run:
        `$BT_DETECT_EXEC --ble -t $BT_DETECT_TIMEOUT @ALL_MACS`
        -repeat until output 'FOUND=<MAC>' or ${MAX_ELAPSED_BT_DETECT}s elapses
      -select the device with the found <MAC> if 'FOUND=<MAC>'
      -select the first device if no <MAC> is found
      -print device information associated with the selected device

  $EXEC --run | run
    kill any $BLE_HRL_EXEC procs and run $BLE_HRL_EXEC
      -get <MAC> as in `$EXEC --detect-mac`
      -run: pkill -f BLEHeartRateLogger.py
      -run: $BLE_HRL_EXEC -b -v -m <MAC>

  $EXEC --start | start
    run --stop, and then start screen-daemon
      -stop as in: `$EXEC --stop`
      -run: screen-daemon hrmon --start

  $EXEC --stop | stop
    stop screen-daemon and kill any other $BLE_HRL_EXEC procs
      -run: screen-daemon hrmon --stop
      -run: pkill -f BLEHeartRateLogger.py

  $EXEC --status | status
    print 'on' or 'off' if screen daemon is running
      -get <STATUS> as 'on' or 'off'
        -run: screen-daemon hrmon --status
      -print '<STATUS>'

  $EXEC --last | last
    -get all log files at:
      $LOG_DIR/*.log*
    -search for the string 'Heart rate'
    -use xzgrep to select the latest file (last sorted by filename) that matches
    -select the last line that matches
    -if no line in any file matches:
      -print 'none'
    -otherwise, ensure selected line is formatted:
      '<DATETIME_FMT>  Heart rate: <HEARTRATE>'
      where <DATETIME_FMT> is the date/time formatted 'YYYY-mm-dd HH:MM:SS,NNN'
        and <HEARTRATE> is a non-negative integer
    -format the selected line:
      -parse the DATETIME_FMT, compare to current time and get ELAPSED_TIME_S
      -format ELAPSED_TIME_S as value ELAPSED_TIME_FMT with optional units days/hours/minutes
                    '#s'
                 '#m##s'
              '#h##m##s'
           '#d##h##m##s'
      -calculate DIRECTION
        -if DATETIME_FMT is in the past (should always be the case): 'ago'
        -otherwise: 'in the future'
      -print '<HEARTRATE_FMT> (<ELAPSED_TIME_FMT> <DIRECTION>)'
        e.g.: 90 (3d04h22m3s ago)

  $EXEC --rotate-logs | rotate-logs | logs
    stop monitoring, compress all logs, and restart if was running
      -get PREV_STATUS as in: STATUS=`$EXEC --status`
      -run: $EXEC --stop
      -run: bzip2 $LOG_DIR/*.log
      -if \$PREV_STATUS = 'on':
        run: $EXEC --start
";

my $CMD_ENSURE_ATTACH = "ensure-attach";
my $CMD_DETECT_DEV = "detect-dev";
my $CMD_RUN = "run";
my $CMD_START = "start";
my $CMD_STOP = "stop";
my $CMD_STATUS = "status";
my $CMD_LAST = "last";
my $CMD_GET = "get";
my $CMD_ROTATE_LOGS = "rotate-logs";

sub main(@){
  my $cmd = $CMD_ENSURE_ATTACH;
  while(@_ > 0){
    my $arg = shift @_;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(--screen-daemon|--ensure-attach|ensure-attach)$/){
      $cmd = $CMD_ENSURE_ATTACH;
    }elsif($arg =~ /^(--mac|--dev|--detect-dev|--detect-mac)$/){
      $cmd = $CMD_DETECT_DEV;
    }elsif($arg =~ /^(--run|run)$/){
      $cmd = $CMD_RUN;
    }elsif($arg =~ /^(--start|start)$/){
      $cmd = $CMD_START;
    }elsif($arg =~ /^(--stop|stop)$/){
      $cmd = $CMD_STOP;
    }elsif($arg =~ /^(--status|status)$/){
      $cmd = $CMD_STATUS;
    }elsif($arg =~ /^(--last|last)$/){
      $cmd = $CMD_LAST;
    }elsif($arg =~ /^(--get|get|-g|g)$/){
      $cmd = $CMD_GET;
    }elsif($arg =~ /^(--rotate-logs|rotate-logs|logs)$/){
      $cmd = $CMD_ROTATE_LOGS;
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }

  if($cmd eq $CMD_ENSURE_ATTACH){
    exec "screen-daemon", "hrmon", "--ensure-attach";
  }elsif($cmd eq $CMD_DETECT_DEV){
    my $dev = detectDevice();
    my @args;
    @args = (@args, defined $$dev{readHandle} ? ("-H", $$dev{readHandle}) : ());
    @args = (@args, defined $$dev{ctlHandle} ? ("-C", $$dev{ctlHandle}) : ());

    print "$$dev{devType}: | $$dev{mac} | args: (@args)\n";
  }elsif($cmd eq $CMD_RUN){
    my $dev = detectDevice();
    my @readHandleArg = defined $$dev{readHandle} ? ("-H", $$dev{readHandle}) : ();
    my @ctlHandleArg = defined $$dev{ctlHandle} ? ("-C", $$dev{ctlHandle}) : ();
    exec $BLE_HRL_EXEC,
      "-b",             #display battery
      "-v",             #display rr
      @readHandleArg,   #override auto-detect of gatttool handle for hr notify
      @ctlHandleArg,    #override auto-detect of gatttool handle for hr request
      "-t", "public",   #pass '-t public' to gatttool instead of '-t random'
      "-m", $$dev{mac}, #device bt mac
    ;
  }elsif($cmd eq $CMD_START){
    stopHrmon();
    run "screen-daemon", "hrmon", "--start";
  }elsif($cmd eq $CMD_STOP){
    stopHrmon();
  }elsif($cmd eq $CMD_STATUS){
    run "screen-daemon", "hrmon", "--status";
  }elsif($cmd eq $CMD_LAST){
    my ($hr, $epoch) = getLastHeartrateLogEntry();
    if(not defined $hr){
      print "none\n";
    }else{
      print "$hr (" . formatRelativeTime($epoch) . ")\n";
    }
  }elsif($cmd eq $CMD_GET){
    my $status = readProc "screen-daemon", "hrmon", "--status";
    if($status =~ /^off$/){
      print "off\n";
    }elsif($status =~ /^on$/){
      my ($hr, $epoch) = getLastHeartrateLogEntry();
      my $diff = time - $epoch;
      $diff = 0-$diff if $diff < 0; #allow 'recent' future values, just in case
      if($diff < $ELAPSED_TIME_THRESHOLD_SECONDS){
        print "$hr\n";
      }else{
        print "waiting\n";
      }
    }else{
      die "ERROR: invalid status '$status'\n";
    }
  }elsif($cmd eq $CMD_ROTATE_LOGS){
    system "mkdir", "-p", $LOG_DIR;
    my @logFiles = sort glob "$LOG_DIR/*.log";
    if(@logFiles == 0){
      print "skipping, no uncompressed log files available in $LOG_DIR\n";
      exit 0;
    }

    my $status = `screen-daemon hrmon --status`;
    stopHrmon();
    run "bzip2", @logFiles;
    if(-l "$LOG_DIR/latest"){
      #remove latest symlink if present, since compressing breaks it
      run "rm", "$LOG_DIR/latest";
    }

    if($status =~ /on/){
      stopHrmon();
      print "re-starting screen-daemon\n";
      run "screen-daemon", "hrmon", "--start";
    }
  }else{
    die "ERROR: unknown cmd $cmd\n"
  }
}

sub detectDevice(){
  die "ERROR: no MACs found\n" if @ALL_MACS == 0;
  my $mac = undef;
  my $defaultMac = $ALL_MACS[0];
  my $start = time;
  my $h2 = "[0-9a-f][0-9a-f]";
  print "SEARCHING FOR MAC\n";
  while(time - $start < $MAX_ELAPSED_BT_DETECT){
    my $out = `$BT_DETECT_EXEC -v --ble -t $BT_DETECT_TIMEOUT @ALL_MACS`;
    if($out =~ /FOUND=($h2:$h2:$h2:$h2:$h2:$h2)/i){
      my $macFound = $1;
      print "  device detected: $macFound\n";
      $mac = $macFound;
      last;
    }
  }
  if(not defined $mac){
    print "search timeout, using default $defaultMac\n";
    $mac = $defaultMac;
  }

  for my $dev(@$DEVICES){
    if($$dev{mac} =~ /$mac/i){
      return $dev;
    }
  }
  die "ERROR: no device found\n";

  return $defaultMac;
}

sub getLogFiles(){
  return reverse sort grep {-f $_} glob "$LOG_DIR/*.log*";
}

sub getLastHeartrateLogEntry(){
  my $foundLine = undef;
  my $foundLogFile = undef;
  for my $logFile(getLogFiles()){
    my $line = readProc "sh", "-c", "tac '$logFile' | xzgrep -m 1 'Heart rate'";
    if($line =~ /Heart rate/){
      $foundLine = $line;
      $foundLogFile = $logFile;
      last;
    }
  }

  if(not defined $foundLine){
    return (undef, undef);
  }elsif($foundLine =~ /^(\d\d\d\d-\d\d-\d\d) (\d\d:\d\d:\d\d),(\d\d\d)\s+Heart rate:\s*(\d+)$/){
    my ($ymd, $hms, $millis, $heartrate) = ($1, $2, $3, $4);
    my $epoch = str2time "${ymd}T${hms}";
    return ($heartrate, $epoch);
  }else{
    die "ERROR: invalid log line format in $foundLogFile:\n$foundLine\n";
  }
}

sub formatRelativeTime($){
  my ($epoch) = @_;
  my $diff = time - $epoch;
  my $isNegative = $diff < 0;
  $diff = 0-$diff if $isNegative;

  my $s = int($diff % 60);
  my $m = int($diff / 60 % 60);
  my $h = int($diff / 60 / 60 % 24);
  my $d = int($diff / 60 / 60 / 24);

  my $fmt;
  if($d > 0){
    $fmt = sprintf "%dd%02dh%02dm%02ds", $d, $h, $m, $s;
  }elsif($h > 0){
    $fmt = sprintf "%dh%02dm%02ds", $h, $m, $s;
  }elsif($m > 0){
    $fmt = sprintf "%dm%02ds", $m, $s;
  }else{
    $fmt = sprintf "%dds", $m, $s;
  }

  my $direction = $isNegative ? "in the future" : "ago";
  return "$fmt $direction";
}

sub readProc(@){
  my @cmd = @_;
  open my $cmdFH, "-|", @cmd or die "ERROR: could not run @cmd\n$!\n";
  my @lines = <$cmdFH>;
  close $cmdFH;
  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;
  }
}

sub stopHrmon(){
  run "screen", "-wipe";
  run "screen-daemon", "hrmon", "--stop";
  run "screen", "-wipe";
  run "pkill", "-f", $BLE_HRL_EXEC;
}

sub run(@){
  print "@_\n";
  system @_;
}

&main(@ARGV);
