#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);

sub getEmailFmt($);
sub getBatteryFmt($);
sub formatEvent($$);
sub getUnreadEvents();
sub parseEventType($$$);
sub getContacts();
sub readFile($);
sub writeFile($$);

my $EXEC = basename $0;
my $USER = "nemo";

my $EXEC_UDO = "udo";
my $EXEC_LOCK = "lock";

my $FILE_CUSTOM_TEXT = "/tmp/custom-lock-item.txt";

my $COMMHISTORY_DB = "/home/$USER/.local/share/commhistory/commhistory.db";
my $CONTACTS_DB =
  "/home/$USER/.local/share/system/privileged/Contacts/qtcontacts-sqlite/contacts.db";

my $EMAIL_STATUS_LINE_FILE = "/home/$USER/.cache/email/status-line";

my $MAX_LINE_LEN = 28;

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC
    -generate $FILE_CUSTOM_TEXT
    -run: $EXEC_UDO $EXEC_LOCK --lpm-refresh
";

my $EVENT_CALL_INBOUND_MISSED = "call-inbound-missed";
my $EVENT_CALL_INBOUND = "call-inbound";
my $EVENT_CALL_OUTBOUND = "call-outbound";
my $EVENT_SMS_INBOUND = "sms-inbound";
my $EVENT_SMS_OUTBOUND = "sms-outbound";

sub main(@){
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }else{
      die "ERROR: unknown arg $arg\n";
    }
  }

  my $contents = "";

  my $email = getEmailFmt($MAX_LINE_LEN - 5);
  my $bat = getBatteryFmt(4);

  $contents .= "$email|$bat\n";

  for my $event(getUnreadEvents()){
    $contents .= formatEvent($event, $MAX_LINE_LEN);
  }

  writeFile($FILE_CUSTOM_TEXT, $contents);

  system $EXEC_UDO, $EXEC_LOCK, "--lpm-refresh";
}

sub getEmailFmt($){
  my ($len) = @_;
  my $email;
  if(-e $EMAIL_STATUS_LINE_FILE){
    $email = readFile $EMAIL_STATUS_LINE_FILE;
    chomp $email;
  }else{
    $email = "";
  }

  $email = substr $email, 0, $len;
  return sprintf "%-${len}s", $email;
}

sub getBatteryFmt($){
  my ($len) = @_;

  my $bat = `bat --get 2>/dev/null`;
  chomp $bat;

  my ($cap, $status);
  if($bat =~ /^(\d+) (\w+)$/){
    ($cap, $status) = ($1, $2);
  }else{
    ($cap, $status) = ("???", "");
  }

  my $capLen = $len - 1;
  $cap = sprintf "%${capLen}s", $cap;

  return "$cap%";
}

sub formatEvent($$){
  my ($event, $len) = @_;

  #skip all unread calls except for missed inbound calls
  return "" if $$event{eventType} eq $EVENT_CALL_INBOUND;
  return "" if $$event{eventType} eq $EVENT_CALL_OUTBOUND;

  #skip unread outbound sms
  return "" if $$event{eventType} eq $EVENT_SMS_OUTBOUND;

  my $contact = $$event{name};
  $contact = "" if not defined $contact;
  if($contact !~ /\w/){
    $contact = $$event{num};
  }

  my $msg = $$event{text};
  $msg = "" if not defined $msg;
  $msg =~ s/^"//;
  $msg =~ s/"$//;

  $msg = "MISSED CALL" if $$event{eventType} eq $EVENT_CALL_INBOUND_MISSED;

  my $maxContactLen = 10;
  my $maxMsgLen = $len - $maxContactLen - 2;

  $contact = substr $contact, 0, $maxContactLen;
  $msg = substr $msg, 0, $maxMsgLen;

  return sprintf "%-${maxContactLen}s: %${maxMsgLen}s\n", $contact, $msg;
}

sub getUnreadEvents(){
  my $sql = ""
     . " SELECT"
     . "   type,"
     . "   direction,"
     . "   isMissedCall,"
     . "   remoteUid,"
     . "   freeText"
     . " FROM Events"
     . " WHERE isRead=0;"
  ;
  my @lines = `sqlite3 --csv $COMMHISTORY_DB "$sql"`;
  my $contacts = getContacts();

  my @events;
  for my $line(@lines){
    if($line =~ /^(\d+),(\d+),(\d+),([0-9\+]+),(.*)$/){
      my ($type, $dir, $isMissedCall, $phone, $text) = ($1, $2, $3, $4, $5);

      $phone = $1 if $phone =~ /^\+1(\d\d\d\d\d\d\d\d\d\d)$/;
      push @events, {
        name      => $$contacts{$phone},
        num       => $phone,
        eventType => parseEventType($type, $dir, $isMissedCall),
        text      => $text,
      };
    }else{
      die "ERROR: malformed query output $line\n";
    }
  }
  return @events;
}

sub parseEventType($$$){
  my ($type, $direction, $isMissedCall) = @_;
  if($type == 3 and $direction == 1 and $isMissedCall == 1){
    return $EVENT_CALL_INBOUND_MISSED;
  }elsif($type == 3 and $direction == 1 and $isMissedCall == 0){
    return $EVENT_CALL_INBOUND;
  }elsif($type == 3 and $direction == 2){
    return $EVENT_CALL_OUTBOUND;
  }elsif($type == 2 and $direction == 1){
    return $EVENT_SMS_INBOUND;
  }elsif($type == 2 and $direction == 2){
    return $EVENT_SMS_OUTBOUND;
  }else{
    return undef;
  }
}

sub getContacts(){
  my $sql = ""
    . " SELECT distinct"
    . "   p.phonenumber"
    . "   || ','"
    . "   || ifnull(n.firstName, '') || ' ' || ifnull(n.lastName, '')"
    . " from names n"
    . "   join phonenumbers p"
    . "   on n.contactid = p.contactid"
  ;

  my @lines = `sudo sqlite3 $CONTACTS_DB "$sql"`;

  my $contacts = {};
  for my $line(@lines){
    if($line =~ /^([^,]+),(.+)$/){
      my ($num, $name) = ($1, $2);
      $num =~ s/[\-\(\)]//g;
      $num =~ s/^\+1//g;
      $num =~ s/[^0-9]+//g;
      $name =~ s/^\s+//;
      $name =~ s/\s+$//;
      $$contacts{$num} = $name;
    }
  }

  return $contacts;
}

sub readFile($){
  my ($file) = @_;
  open FH, "< $file" or die "ERROR: could not read $file\n$!\n";
  my @lines = <FH>;
  close FH;
  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;;
  }
}

sub writeFile($$){
  my ($file, $content) = @_;
  open FH, "> $file" or die "ERROR: could not write $file\n$!\n";
  print FH $content;
  close FH;
}

&main(@ARGV);
