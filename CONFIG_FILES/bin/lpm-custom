#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);

sub formatEvent($);
sub getUnreadEvents();
sub parseEventType($$$);
sub readFile($);
sub writeFile($$);

my $EXEC = basename $0;
my $USER = "nemo";

my $EXEC_UDO = "udo";
my $EXEC_LOCK = "lock";

my $FILE_CUSTOM_TEXT = "/tmp/custom-lock-item.txt";

my $COMMHISTORY_DB = "/home/$USER/.local/share/commhistory/commhistory.db";

my $EMAIL_STATUS_LINE_FILE = "/home/$USER/.cache/email/status-line";

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC
    -generate $FILE_CUSTOM_TEXT
    -run: $EXEC_UDO $EXEC_LOCK --lpm-refresh
";

my $EVENT_CALL_INBOUND_MISSED = "call-inbound-missed";
my $EVENT_CALL_INBOUND = "call-inbound";
my $EVENT_CALL_OUTBOUND = "call-outbound";
my $EVENT_SMS_INBOUND = "sms-inbound";
my $EVENT_SMS_OUTBOUND = "sms-outbound";

sub main(@){
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }else{
      die "ERROR: unknown arg $arg\n";
    }
  }

  my $contents = "";

  if(-e $EMAIL_STATUS_LINE_FILE){
    $contents .= readFile $EMAIL_STATUS_LINE_FILE;
  }

  for my $event(getUnreadEvents()){
    $contents .= formatEvent($event);
  }

  $contents .= `date +'%s.%3N'`;

  writeFile($FILE_CUSTOM_TEXT, $contents);

  system $EXEC_UDO, $EXEC_LOCK, "--lpm-refresh";
}

sub formatEvent($){
  my ($event) = @_;
  return "$$event{eventType} $$event{num}\n";
}

sub getUnreadEvents(){
  my $sql = ""
     . " SELECT"
     . "   type,"
     . "   direction,"
     . "   isMissedCall,"
     . "   remoteUid,"
     . "   freeText"
     . " FROM Events"
     . " WHERE isRead=0;"
  ;
  my @lines = `sqlite3 --csv $COMMHISTORY_DB "$sql"`;

  my @events;
  for my $line(@lines){
    if($line =~ /^(\d+),(\d+),(\d+),([0-9\+]+),(.*)$/){
      my ($type, $dir, $isMissedCall, $phone, $text) = ($1, $2, $3, $4, $5);

      $phone = $1 if $phone =~ /^\+1(\d\d\d\d\d\d\d\d\d\d)$/;
      push @events, {
        num       => $phone,
        eventType => parseEventType($type, $dir, $isMissedCall),
        text      => $text,
      };
    }else{
      die "ERROR: malformed query output $line\n";
    }
  }
  return @events;
}

sub parseEventType($$$){
  my ($type, $direction, $isMissedCall) = @_;
  if($type == 3 and $direction == 1 and $isMissedCall == 1){
    return $EVENT_CALL_INBOUND_MISSED;
  }elsif($type == 3 and $direction == 1 and $isMissedCall == 0){
    return $EVENT_CALL_INBOUND;
  }elsif($type == 3 and $direction == 2){
    return $EVENT_CALL_OUTBOUND;
  }elsif($type == 2 and $direction == 1){
    return $EVENT_SMS_INBOUND;
  }elsif($type == 2 and $direction == 2){
    return $EVENT_SMS_OUTBOUND;
  }else{
    return undef;
  }
}

sub readFile($){
  my ($file) = @_;
  open FH, "< $file" or die "ERROR: could not read $file\n$!\n";
  my @lines = <FH>;
  close FH;
  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;;
  }
}

sub writeFile($$){
  my ($file, $content) = @_;
  open FH, "> $file" or die "ERROR: could not write $file\n$!\n";
  print FH $content;
  close FH;
}

&main(@ARGV);
