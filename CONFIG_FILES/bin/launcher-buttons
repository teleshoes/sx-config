# APP_NAME_ALIAS => REAL_DESKTOP_FILE_REGEX
my %REPLACEMENT_REGEXS_WAYDROID = map {$_ => "^android-wd-$_\$"} sort keys %ANDROID_LAUNCHERS;

# APP_NAME_ALIAS => REAL_DESKTOP_FILE_REGEX
my %REPLACEMENT_REGEXS_ALIENDALVIK = map {$_ => "^android-ad-$_\$"} sort keys %ANDROID_LAUNCHERS;

# APP_NAME_ALIAS => REAL_DESKTOP_FILE_REGEX
my %REPLACEMENT_REGEXS = (
  'phone'            => qw/^voicecall-ui$/,
  'documents'        => qw/^sailfish-office$/,
  'lirrgui'          => qw/^lirrtraintime$/,

  ($USE_WAYDROID ? %REPLACEMENT_REGEXS_WAYDROID : ()),
  ($USE_ALIENDALVIK ? %REPLACEMENT_REGEXS_ALIENDALVIK : ()),
);

#desktop files with no launchers
