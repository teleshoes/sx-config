my @DESKTOP_FILE_DISABLE_PATTERNS = qw(
  jolla-email
  sailfish-weather
  sailfish-tutorial
  google-tts
  vanced-microg
  ivona-tts
  ivona-tts-amy
);

my @DESKTOP_FILE_DISABLE_FREEZE_PATTERNS = (
  ### skip freezing apkd launchers, move to apkd dir instead
  # "apkd_launcher_*-*",
);

my @OPTIONAL_PREFIXES = qw(
  jolla-
  harbour-
  android-wd-
  android-ad-
);
my %PATTERN_SYNONYMS = (
  phone     => "voicecall-ui",
  documents => "sailfish-office",
  lirrgui   => "lirrtraintime",
);

my $MODE_APPLY = "apply";
my $MODE_CHECK = "check";
my $MODE_GET_DESKTOP_FILES = "get-desktop-files";

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC
    same as: $EXEC --apply

  $EXEC [OPTS] --apply
    apply launcher config
      -ensure script is running on device
        -if not, copy script to device and execute it over ssh
      -stop lipstick
      -create/disable desktop files:
        -remove all previously created custom android launchers
        -create custom android launchers for aliendalivk/appsupport or waydroid
        -restore+enable previously backed up disabled launchers
        -backup+disable configured launchers
      -configure lipstick:
        -create directory entries for lipstick menu
        -create lipstick applications.menu with ordered launchers
      -run $EXEC --check

  $EXEC [OPTS] --check
    check that all config/disabled patterns match desktop files and vice-versa
      -for each PATTERN in CONFIG_PATTERNS:
        -get CFG_DESKTOP_FILES as in: $EXEC --get-matching-desktop-files <CONFIG_PATTERN>
        -if CFG_DESKTOP_FILES is empty:
          -print 'MISSING: <CONFIG_PATTERN>'
        -append CFG_DESKTOP_FILES files to ALL_MATCHING_DESKTOP_FILES_LIST
      -for each PATTERN in IGNORED_PATERNS:
        -get CFG_DESKTOP_FILES as in: $EXEC --get-matching-desktop-files <CONFIG_PATTERN>
        -append CFG_DESKTOP_FILES files to ALL_MATCHING_DESKTOP_FILES_LIST
      -for each DESKTOP_FILE in `$EXEC --get-all-desktop-files`:
        -check if DESKTOP_FILE contents contains the line 'NoDisplay=true'
          -if not, ensure DESKTOP_FILE is contained in ALL_MATCHING_DESKTOP_FILES_LIST
            -if DESKTOP_FILE is not in ALL_MATCHING_DESKTOP_FILES_LIST:
              -print 'EXTRA: <DESKTOP_FILE>'

  $EXEC [OPTS] --get-matching-desktop-files PATTERN
    get matching desktop files, enabled or disabled, in main + home launcher directories
      -if PATTERN has a PATTERN_SYNONYM:
        -use PATTERN_REAL=PATTERN_SYNONYM
      -otherwise:
        -use PATTERN_REAL=PATTERN
      -use PREFIX_GLOB=?(" . join("|", @OPTIONAL_PREFIXES) . ")
      -list all desktop files that match:
        $DIR_ACTIVE_LAUNCHERS_MAIN/<PREFIX_GLOB><PATTERN_REAL>.desktop*
        $DIR_ACTIVE_LAUNCHERS_HOME/<PREFIX_GLOB><PATTERN_REAL>.desktop*

  $EXEC [OPTS] --get-all-desktop-files
    get all desktop files, enabled or disabled, in main + home launcher directories
      -list all desktop files that match:
        $DIR_ACTIVE_LAUNCHERS_MAIN/*.desktop*
        $DIR_ACTIVE_LAUNCHERS_HOME/*.desktop*

  OPTS
    -k | --keep-lipstick | --no-restart-lipstick
      do not kill lipstick
      do not stop, start, or restart lipstick service
";

sub main(@){
  my $mode = $MODE_APPLY;
  my $targetPattern = undef;
  my $opts = {
    restartLipstick => 1,
  };
  while(@_ > 0){
    my $arg = shift @_;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(--apply)$/){
      $mode = $MODE_APPLY;
    }elsif($arg =~ /^(--check)$/){
      $mode = $MODE_CHECK;
    }elsif($arg =~ /^(--get-matching-desktop-files)$/){
      die "ERROR: missing PATTERN\n" if @_ == 0;
      $mode = $MODE_GET_DESKTOP_FILES;
      $targetPattern = shift @_;
    }elsif($arg =~ /^(--get-all-desktop-files)$/){
      $mode = $MODE_GET_DESKTOP_FILES;
      $targetPattern = undef;
    }elsif($arg =~ /^(-k|--keep-lipstick|--no-restart-lipstick)$/){
      $$opts{restartLipstick} = 0;
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }

  ensureExecScriptOnDevice();

  die "must be run as root\n" if `whoami` ne "root\n";

  if($mode eq $MODE_APPLY){
    stopLipstick() if $$opts{restartLipstick};
    applyLauncherConfig();
    startLipstick() if $$opts{restartLipstick};

    checkLauncherConfig();
  }elsif($mode eq $MODE_CHECK){
    checkLauncherConfig();
  }elsif($mode eq $MODE_GET_DESKTOP_FILES){
    my @desktopFiles = defined $targetPattern ?
      getDesktopFilesByPattern($targetPattern) : getAllDesktopFiles();
    print "$_\n" foreach @desktopFiles;
  }else{
    die "ERROR: unknown mode $mode\n";
  }
}

sub ensureExecScriptOnDevice(){
  my $targetHost = `ipmagic $IPMAGIC_NAME 2>/dev/null`;
  chomp $targetHost;
  my $actualHost = `hostname`;
  chomp $actualHost;
  if(length $targetHost > 0 and $targetHost ne $actualHost){
    my $host = `ipmagic $IPMAGIC_NAME`;
    chomp $host;
    my $name = basename $0;
    print "copying to the device\n";
    system "scp", $0, "root\@$host:/tmp/$name";
    print "rerunning on the device\n";
    exec "ssh", "root\@$host", "/tmp/$name", @ARGV;
  }
}

sub startLipstick(){
  run "udo systemctl --user restart lipstick";
}
sub stopLipstick(){
  run "udo systemctl --user stop lipstick &";
  run "pkill -9 lipstick";
}

sub checkLauncherConfig(){
  print "\nchecking launcher config:\n";
  my $countMissing = 0;
  my %handledDesktopFiles;
  for my $ptrn(@CONFIG){
    next if $ptrn =~ /^(dir%.*\[|\])$/; #skip dir open/close entries

    my @desktopFiles = getDesktopFilesByPattern($ptrn);
    if(@desktopFiles == 0){
      print "MISSING: $ptrn\n";
      $countMissing++;
    }
    $handledDesktopFiles{$_} = 1 foreach @desktopFiles;
  }
  for my $ptrn(@DESKTOP_FILE_DISABLE_PATTERNS, @DESKTOP_FILE_DISABLE_FREEZE_PATTERNS){
    my @desktopFiles = getDesktopFilesByPattern($ptrn);
    $handledDesktopFiles{$_} = 1 foreach @desktopFiles;
  }

  my $countExtra = 0;
  for my $desktopFile(getAllDesktopFiles()){
    if(not defined $handledDesktopFiles{$desktopFile}){
      my $noDisplayAtt = readProc "grep", "^NoDisplay", $desktopFile;
      if($noDisplayAtt =~ /^NoDisplay=true$/){
        #ignore launchers with no launcher display
        next;
      }else{
        print "EXTRA: $desktopFile\n";
        $countExtra++;
      }
    }
  }

  print "missing=$countMissing, extra=$countExtra\n";
}

sub applyLauncherConfig(){
  initializeAllAndroidDesktopFiles();

  unfreezeAllDesktopFiles();

  enableAllDesktopFiles();

  for my $ptrn(@DESKTOP_FILE_DISABLE_PATTERNS){
    for my $desktopFile(getDesktopFilesByPattern($ptrn)){
      disableDesktopFile($desktopFile, 0);
    }
  }
  for my $ptrn(@DESKTOP_FILE_DISABLE_FREEZE_PATTERNS){
    for my $desktopFile(getDesktopFilesByPattern($ptrn)){
      disableDesktopFile($desktopFile, 1);
    }
  }

  writeLipstickConfig(@CONFIG);
}

sub initializeAllAndroidDesktopFiles(){
  removeAllAndroidDesktopFiles();

  initializeAndroidAppIcons();

  for my $appName(sort keys %ANDROID_LAUNCHERS){
    createAndroidDesktopFile($appName);
  }
}

sub removeAllAndroidDesktopFiles(){
  run "rm -f $DIR_ACTIVE_LAUNCHERS_MAIN/android-wd-*.desktop*";
  run "rm -f $DIR_ACTIVE_LAUNCHERS_MAIN/android-ad-*.desktop*";
}

sub initializeAndroidAppIcons(){
  if($USE_WAYDROID){
    run "mkdir", "-p", $DIR_WAYDROID_APP_ICON_BACKUP;
    run "rsync", "-avP",
      "$DIR_WAYDROID_APP_ICON_SRC/",
      "$DIR_WAYDROID_APP_ICON_BACKUP/",
    ;
    run "mkdir", "-p", $DIR_WAYDROID_APP_ICON_DEST;
    run "rsync", "-avP",
      "$DIR_WAYDROID_APP_ICON_BACKUP/",
      "$DIR_WAYDROID_APP_ICON_DEST/",
    ;
    run "chown",
      "-R",
      "$DIR_WAYDROID_APP_ICON_DEST/",
      "--reference=$DIR_WAYDROID_APP_ICON_DEST/../",
    ;
  }
  if($USE_ALIENDALVIK){
    my $adIcons = {};
    for my $iconFile(glob "$DIR_ALIENDALVIK_APP_ICON_SRC/*.png"){
      if($iconFile =~ /apkd_launcher_(\w+)-(.+).png/){
        my ($pkgNameFmt, $intentFmt) = ($1, $2);
        $pkgNameFmt =~ s/__/_/g;
        $$adIcons{$pkgNameFmt} = $iconFile;
      }
    }

    my %missingIconPkgByAppName;

    run "mkdir", "-p", $DIR_ALIENDALVIK_APP_ICON_BACKUP;
    for my $appName(sort keys %ANDROID_LAUNCHERS){
      my ($isWaitMount, $pkg, $intent, $iconPath) = @{$ANDROID_LAUNCHERS{$appName}};
      my $pkgNameFmt = $pkg;
      $pkgNameFmt =~ s/\W/_/g;
      my $iconFile = $$adIcons{$pkgNameFmt};
      if(defined $iconFile){
        runQuiet "cp", "-ar", "$iconFile", "$DIR_ALIENDALVIK_APP_ICON_BACKUP/$pkg.png";
      }else{
        $missingIconPkgByAppName{$appName} = $pkg;
      }
    }

    my @missingIconWarningLines;
    for my $appName(sort keys %missingIconPkgByAppName){
      my $pkg = $missingIconPkgByAppName{$appName};
      my $isDisabled = 0;
      for my $ptrn(@DESKTOP_FILE_DISABLE_PATTERNS, @DESKTOP_FILE_DISABLE_FREEZE_PATTERNS){
        my $regex = $ptrn;
        $regex =~ s/\*/.*/g;
        if($appName =~ /^$regex$/){
          $isDisabled = 1;
          last;
        }
      }
      if(not $isDisabled){
        #ignore missing icons for disabled apps (usually APKs without launchers)
        push @missingIconWarningLines, "  $appName - $pkg\n";
      }
    }
    if(@missingIconWarningLines > 0){
      my $msg = "no aliendalvik icons found for:\n" . join("", @missingIconWarningLines);
      print "\n\nWARNING: $msg\n";
    }

    run "mkdir", "-p", $DIR_ALIENDALVIK_APP_ICON_DEST;
    run "rsync", "-avP",
      "$DIR_ALIENDALVIK_APP_ICON_BACKUP/",
      "$DIR_ALIENDALVIK_APP_ICON_DEST/",
    ;
    run "chown",
      "-R",
      "$DIR_ALIENDALVIK_APP_ICON_DEST/",
      "--reference=$DIR_ALIENDALVIK_APP_ICON_DEST/../",
    ;
  }
}

sub createAndroidDesktopFile($){
  my ($appName) = @_;

  my ($isWaitMount, $pkg, $action, $iconPathOverride) = @{$ANDROID_LAUNCHERS{$appName}};

  my $fullIntent = "$pkg/$action";

  my $cmd;
  my $desktopFilePrefix;
  my $androidIconDir;
  my $androidEnvDesc;
  if($USE_ALIENDALVIK){
    $cmd = "ad";
    $cmd .= " --skip-mount" unless $isWaitMount;
    $cmd .= " --app $appName '$fullIntent'";
    $desktopFilePrefix = "android-ad";
    $androidIconDir = $DIR_ALIENDALVIK_APP_ICON_DEST;
    $androidEnvDesc = "aliendalvik";
  }elsif($USE_WAYDROID){
    $cmd = "/usr/local/bin/udo wd --launch-intent=\"$fullIntent\"";
    $desktopFilePrefix = "android-wd";
    $androidIconDir = $DIR_WAYDROID_APP_ICON_DEST;
    $androidEnvDesc = "waydroid";
  }else{
    die "ERROR: no android environment configured\n";
  }

  my $iconPath = "$androidIconDir/$pkg.png";
  $iconPath = $iconPathOverride if defined $iconPathOverride;

  my $desktopFile = "$DIR_ACTIVE_LAUNCHERS_MAIN/$desktopFilePrefix-$appName.desktop";
  my $desktopContents = ""
    . "[Desktop Entry]\n"
    . "Name=$appName\n"
    . "Comment=Run $fullIntent in $androidEnvDesc\n"
    . "Icon=$iconPath\n"
    . "Exec=$cmd\n"
    . "Type=Application\n"
    . "X-Nemo-Single-Instance=no\n"
    . "Custom-Launcher=yes\n"
    . "\n"
    . "[X-Sailjail]\n"
    . "Sandboxing=Disabled\n"
    ;

  open FH, "> $desktopFile" or die "ERROR: cannot write $desktopFile\n$!\n";
  print FH $desktopContents;
  close FH;
}

sub getAllDesktopFiles(){
  my @allDesktopFiles = grep {-f $_} (
    glob("$DIR_ACTIVE_LAUNCHERS_MAIN/*.desktop*"),
    glob("$DIR_ACTIVE_LAUNCHERS_HOME/*.desktop*"),
  );
  return @allDesktopFiles;
}

sub getDesktopFilesByPattern($){
  my ($ptrn) = @_;

  # ignore 'dir%*%*[' and ']' config items
  if($ptrn =~ /^(dir%.*\[|\])$/){
    return ();
  }

  if(defined $PATTERN_SYNONYMS{$ptrn}){
    $ptrn = $PATTERN_SYNONYMS{$ptrn};
  }

  my @desktopFiles;
  for my $dir($DIR_ACTIVE_LAUNCHERS_MAIN, $DIR_ACTIVE_LAUNCHERS_HOME){
    for my $prefix(("", @OPTIONAL_PREFIXES)){
      @desktopFiles = (@desktopFiles, glob "$dir/$prefix$ptrn.desktop*");
    }
  }
  @desktopFiles = grep {-f $_} @desktopFiles;

  return @desktopFiles;
}

sub enableDesktopFile($){
  my ($disabledDesktopFile) = @_;
  my ($dir, $enabledFileName) = (undef, undef);
  if($disabledDesktopFile =~ /^(.*)\/([^\/]*\.desktop)\.disabled.*/){
    ($dir, $enabledFileName) = ($1, $2);
  }else{
    die "ERROR: malformed disabled desktop file $disabledDesktopFile\n";
  }

  my $enabledDesktopFile = "$dir/$enabledFileName";
  if(-z $enabledDesktopFile){
    #remove empty placeholder desktop file
    run "rm", "-f", $enabledDesktopFile;
  }
  if(-e $enabledDesktopFile){
    print "\nWARNING: skipping re-enable of $disabledDesktopFile\n";
  }else{
    run "mv", "--no-clobber", $disabledDesktopFile, $enabledDesktopFile;
  }
}

sub disableDesktopFile($$){
  my ($desktopFile, $freeze) = @_;

  #backup + delete desktop files and optionally prevent replacement with chattr +i

  if($desktopFile =~ /\.desktop\.disabled/){
    #already disabled, skip
    return;
  }

  my $fileName = undef;
  $fileName = $2 if $desktopFile =~ /^(.*\/)([^\/]*\.desktop)$/;
  die "ERROR: malformed desktop file $desktopFile\n" if not defined $fileName;

  if(-z $desktopFile){
    #remove empty launcher file without backup
    run "rm", "-f", $desktopFile;
  }else{
    #backup+remove non-empty launcher file
    my $bakFile = "$desktopFile.disabled." . nowMillis();
    run "mv", "--no-clobber", $desktopFile, $bakFile;
  }

  if(-e $desktopFile){
    die "ERROR: could not backup $desktopFile\n";
  }

  if($freeze){
    #create empty placeholder and prevent deletion
    run "touch", $desktopFile;
    run "chattr", "+i", $desktopFile;
  }
}

sub enableAllDesktopFiles(){
  for my $dir($DIR_ACTIVE_LAUNCHERS_MAIN, $DIR_ACTIVE_LAUNCHERS_HOME){
    my @disabledDesktopFiles = grep {-f $_} glob "$dir/*.desktop.disabled*";

    my %desktopFilesByEnabledFileName;
    for my $disabledDesktopFile(@disabledDesktopFiles){
      my $enabledFileName = undef;
      if($disabledDesktopFile =~ /^.*\/([^\/]*\.desktop)\.disabled\.\d+$/){
        $enabledFileName = $1;
      }else{
        die "ERROR: malformed disabled desktop file $disabledDesktopFile\n";
      }
      if(not defined $desktopFilesByEnabledFileName{$enabledFileName}){
        $desktopFilesByEnabledFileName{$enabledFileName} = [];
      }
      push @{$desktopFilesByEnabledFileName{$enabledFileName}}, $disabledDesktopFile;
    }

    for my $enabledFileName(sort keys %desktopFilesByEnabledFileName){
      my @disabledDesktopFiles = @{$desktopFilesByEnabledFileName{$enabledFileName}};
      @disabledDesktopFiles = sort {
        my $aMillis = $1 if $a =~ /\.desktop\.disabled\.(\d+)$/;
        my $bMillis = $1 if $b =~ /\.desktop\.disabled\.(\d+)$/;
        $aMillis <=> $bMillis;
      } @disabledDesktopFiles;

      my $mostRecentDisabledDesktopFile = $disabledDesktopFiles[-1];
      enableDesktopFile($mostRecentDisabledDesktopFile);
    }
  }
}

sub unfreezeAllDesktopFiles(){
  print "running 'chattr -i' on all desktop files\n";
  runQuiet "chattr", "-i", getAllDesktopFiles();
}

sub writeLipstickConfig(@){
  my @config = @_;
  my $xml = "";
  $xml .= "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n";
  $xml .= "<Menu>\n";
  $xml .= "    <Name></Name>\n";
  my $depth = 1;
  my $indent = "    " x $depth;
  my %dirs;
  for my $configItem(@config){
    if($configItem =~ /^dir%(.*)%(.*)\[$/){
      my ($dirName, $icon) = ($1, $2);
      $icon = $DEFAULT_ICON_NAME if $icon eq "";
      my $dirFilePath = "$DIR_LIPSTICK_FOLDER_MENU/dir-$dirName.directory";
      $xml .= "$indent<Menu>\n";
      $xml .= "$indent    <Name>$dirName</Name>\n";
      $xml .= "$indent    <Directory>$dirFilePath</Directory>\n";
      $dirs{$dirFilePath} = $icon;
      $depth++;
      $indent = "    " x $depth;
    }elsif($configItem =~ /^\]$/){
      $depth--;
      $indent = "    " x $depth;
      $xml .= "$indent</Menu>\n"
    }else{
      my @desktopFiles = getDesktopFilesByPattern($configItem);
      for my $desktopFile(@desktopFiles){
        if($desktopFile =~ /^(?:.*\/)?([^\/]*\.desktop)$/){
          my $fileName = $1;
          $xml .= "$indent<Filename>$fileName</Filename>\n";
        }
      }
    }
  }
  $xml .= "</Menu>\n";

  run "rm -f $DIR_LIPSTICK_FOLDER_MENU/*.directory";
  for my $dirFilePath(sort keys %dirs){
    my $icon = $dirs{$dirFilePath};
    my $content = "[Desktop Entry]\nIcon=$icon\n";
    open FH, "> $dirFilePath" or die "Couldnt write to $dirFilePath\n";
    print FH $content;
    close FH;
    run "chown", "$USER.$USER", $dirFilePath;
  }

  open FH, "> $FILE_LIPSTICK_MENU_CONF" or die "Couldnt write to $FILE_LIPSTICK_MENU_CONF\n";
  print FH $xml;
  close FH;
}

sub nowMillis(){
  return int(time * 1000.0 + 0.5);
}

sub readProc(@){
  my (@cmd) = @_;
  open my $cmdH, "-|", @cmd or die "ERROR: could not run @cmd\n$!\n";
  my @lines = <$cmdH>;
  close $cmdH;
  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;
  }
}

sub run(@){
  print "@_\n";
  runQuiet(@_);
}
sub runQuiet(@){
  system @_;
}

&main(@ARGV);
